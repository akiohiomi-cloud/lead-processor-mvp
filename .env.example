# Lead MVP — env template. Copy to .env and fill real values.
# DRY_RUN=true → no external calls (Sheets/Telegram/Anthropic), logs to logs/leads.jsonl.

DRY_RUN=true

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Google Sheets
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_PATH=./service-account.json

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Phone normalization — default region for numbers without country code
PHONE_DEFAULT_REGION=UA
